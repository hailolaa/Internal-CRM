# Mission Control backend staging environment.
# Copy to backend/.env on the staging host or configure these values in the host secret manager.
# Do not reuse clinic-facing CRM production secrets, domains, or database names.

NODE_ENV=production
PORT=4000

FRONTEND_URL=https://mission-control-staging.thegrowthgroup.com
API_PUBLIC_URL=https://api-mission-control-staging.thegrowthgroup.com/api
CORS_ORIGINS=https://mission-control-staging.thegrowthgroup.com
OAUTH_CALLBACK_BASE_URL=https://api-mission-control-staging.thegrowthgroup.com/api/auth

DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=growth_group_internal_crm_staging
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=
JWT_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=10

EMAIL_PROVIDER=brevo
EMAIL_FROM="The Growth Group Mission Control Staging <noreply-staging@thegrowthgroup.com>"
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENAI_DEEP_AUDIT_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_API_URL=https://api.openai.com/v1/audio/transcriptions
OPENAI_INSIGHTS_ENABLED=false
OPENAI_INSIGHTS_MODEL=gpt-5-mini
OPENAI_CALL_INTELLIGENCE_ENABLED=false
OPENAI_CALL_INTELLIGENCE_MODEL=gpt-5-mini
OPENAI_CALL_TRANSCRIPTION_ENABLED=false
OPENAI_CALL_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TIMEOUT_MS=15000

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

WHATSAPP_PROVIDER=log
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_VERIFY_TOKEN=

BACKUP_DIR=backups/staging
BACKUP_RETENTION_DAYS=14
MYSQLDUMP_BIN=mysqldump
MYSQL_BIN=mysql

BACKGROUND_JOBS_ENABLED=false
BACKGROUND_JOBS_POLL_INTERVAL_MS=60000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v24
GOOGLE_DRIVE_VALIDATION_ENABLED=false
GOOGLE_DRIVE_ACCESS_TOKEN=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLAN_STARTER_ID=
STRIPE_PLAN_PROFESSIONAL_ID=

DEMO_SEED_PASSWORD=
DEMO_SEED_SQL=
