# Core
NODE_ENV=development
PORT=4000

# Public URLs / domain for the internal CRM.
# Do not reuse clinic-facing production URLs in this internal project.
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000/api
CORS_ORIGINS=http://localhost:3000
OAUTH_CALLBACK_BASE_URL=http://localhost:4000/api/auth

# Database. This app uses discrete MySQL vars, not DATABASE_URL.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=growth_group_internal_crm
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 2FA
OTP_EXPIRY_MINUTES=10

# Email
EMAIL_PROVIDER=brevo
# Single formatted sender used by the app.
EMAIL_FROM="The Growth Group Internal CRM <noreply@thegrowthgroup.local>"
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# OpenAI
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENAI_DEEP_AUDIT_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_API_URL=https://api.openai.com/v1/audio/transcriptions
OPENAI_INSIGHTS_ENABLED=false
OPENAI_INSIGHTS_MODEL=gpt-5-mini
OPENAI_CALL_INTELLIGENCE_ENABLED=false
OPENAI_CALL_INTELLIGENCE_MODEL=gpt-5-mini
OPENAI_CALL_TRANSCRIPTION_ENABLED=false
OPENAI_CALL_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TIMEOUT_MS=15000

# Twilio call tracking, recording download, and webhook shared-secret gate
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

# Backups
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14
MYSQLDUMP_BIN=mysqldump
MYSQL_BIN=mysql

# Background jobs
BACKGROUND_JOBS_ENABLED=false
BACKGROUND_JOBS_POLL_INTERVAL_MS=60000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v24
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# FACEBOOK_APP_ID and FACEBOOK_APP_SECRET are accepted fallbacks.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Provider placeholders currently represented by manual/staging-safe app flows.
# There are no runtime WhatsApp lead-intake env vars in code yet.

# Stripe. Leave blank unless Mission Control has its own test/internal Stripe setup.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLAN_STARTER_ID=
STRIPE_PLAN_PROFESSIONAL_ID=

# Staging demo seed. This is opt-in and must not use clinic-facing launch data.
# Required by npm run seed:staging-demo. Must be at least 12 characters.
DEMO_SEED_PASSWORD=
# Required seed SQL path. The legacy clinic seed is no longer a default.
DEMO_SEED_SQL=
