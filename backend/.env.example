# Core
NODE_ENV=development
PORT=3000

# Public URLs / domain
FRONTEND_URL=https://clinicgrower.ai
API_PUBLIC_URL=https://clinicgrower.ai/api
CORS_ORIGINS=https://clinicgrower.ai,https://www.clinicgrower.ai
OAUTH_CALLBACK_BASE_URL=https://clinicgrower.ai/api/auth

# Database. This app uses discrete MySQL vars, not DATABASE_URL.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=growth_group_internal_crm
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 2FA
OTP_EXPIRY_MINUTES=10

# Email
EMAIL_PROVIDER=brevo
# Single formatted sender used by the app. Example: "Clinic Grower <noreply@clinicgrower.ai>"
EMAIL_FROM="Clinic Grower <noreply@clinicgrower.ai>"
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# OpenAI
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENAI_DEEP_AUDIT_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_API_URL=https://api.openai.com/v1/audio/transcriptions
OPENAI_INSIGHTS_ENABLED=false
OPENAI_INSIGHTS_MODEL=gpt-5-mini
OPENAI_CALL_INTELLIGENCE_ENABLED=false
OPENAI_CALL_INTELLIGENCE_MODEL=gpt-5-mini
OPENAI_CALL_TRANSCRIPTION_ENABLED=false
OPENAI_CALL_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TIMEOUT_MS=15000

# Twilio call tracking, recording download, and webhook shared-secret gate
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

# Backups
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14
MYSQLDUMP_BIN=mysqldump
MYSQL_BIN=mysql

# Background jobs
BACKGROUND_JOBS_ENABLED=false
BACKGROUND_JOBS_POLL_INTERVAL_MS=60000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v24
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# FACEBOOK_APP_ID and FACEBOOK_APP_SECRET are accepted fallbacks.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Provider placeholders currently represented by manual/staging-safe app flows.
# There are no runtime WhatsApp lead-intake env vars in code yet.

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLAN_STARTER_ID=price_...
STRIPE_PLAN_PROFESSIONAL_ID=price_...

# Staging demo seed
# Required by npm run seed:staging-demo. Must be at least 12 characters.
DEMO_SEED_PASSWORD=
# Optional override; default is seeds/20260609_staging_client_demo_seed.sql.
DEMO_SEED_SQL=
