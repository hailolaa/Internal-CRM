# Mission Control backend production environment.
# Configure these in the production host secret manager; do not commit real values.
# This is The Growth Group internal CRM production target, not clinic-facing CRM production.

NODE_ENV=production
PORT=4000

FRONTEND_URL=https://mission-control.thegrowthgroup.com
API_PUBLIC_URL=https://api-mission-control.thegrowthgroup.com/api
CORS_ORIGINS=https://mission-control.thegrowthgroup.com
OAUTH_CALLBACK_BASE_URL=https://api-mission-control.thegrowthgroup.com/api/auth

DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=growth_group_internal_crm_prod
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=
JWT_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=10

EMAIL_PROVIDER=brevo
EMAIL_FROM="The Growth Group Mission Control <noreply@thegrowthgroup.com>"
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENAI_DEEP_AUDIT_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_API_URL=https://api.openai.com/v1/audio/transcriptions
OPENAI_INSIGHTS_ENABLED=false
OPENAI_INSIGHTS_MODEL=gpt-5-mini
OPENAI_CALL_INTELLIGENCE_ENABLED=false
OPENAI_CALL_INTELLIGENCE_MODEL=gpt-5-mini
OPENAI_CALL_TRANSCRIPTION_ENABLED=false
OPENAI_CALL_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TIMEOUT_MS=15000

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

WHATSAPP_PROVIDER=meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_WORKSPACE_ID=
WHATSAPP_WEBHOOK_WORKSPACE_MAP=

BACKUP_DIR=backups/production
BACKUP_RETENTION_DAYS=30
MYSQLDUMP_BIN=mysqldump
MYSQL_BIN=mysql

BACKGROUND_JOBS_ENABLED=false
BACKGROUND_JOBS_POLL_INTERVAL_MS=60000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v24
GOOGLE_DRIVE_VALIDATION_ENABLED=true
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_SERVICE_ACCOUNT_SUBJECT=
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.metadata.readonly
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLAN_STARTER_ID=
STRIPE_PLAN_PROFESSIONAL_ID=

DEMO_SEED_PASSWORD=
DEMO_SEED_SQL=
