# Frontend public runtime config.
# Only NEXT_PUBLIC_* values are bundled into the browser.

# Public browser-safe HTTPS URL used by the logo image component.
NEXT_PUBLIC_LOGO_URL="https://eu.chat-img.sintra.ai/57e4b3da-c2ee-48f8-956d-828adc30d734/0588879f-1cbe-4b7a-8b40-812b6a74b739/Copy_20of_20Copy_20of_20Clinic-Grower-Logo-Trademark-Light-Centralised-NO-slogan-withBG.png"

# Express backend API URL. Include /api when frontend and backend share a domain.
NEXT_PUBLIC_API_BASE_URL="https://clinicgrower.ai/api"

# Frontend URL used after OAuth redirects.
NEXT_PUBLIC_APP_URL="https://clinicgrower.ai"

# Browser-safe Stripe publishable key for embedded Checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Public feature/config values only. Do not place server secrets here.
