# Frontend public runtime config.
# Only NEXT_PUBLIC_* values are bundled into the browser.

# Optional public browser-safe HTTPS URL used by the logo image component.
# Leave blank to use the built-in The Growth Group Internal CRM wordmark.
NEXT_PUBLIC_LOGO_URL=""

# Express backend API URL for the internal CRM.
# Do not point this internal project at the clinic-facing production API.
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api"

# Frontend URL used after OAuth redirects.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Browser-safe Stripe publishable key for embedded Checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Public feature/config values only. Do not place server secrets here.
